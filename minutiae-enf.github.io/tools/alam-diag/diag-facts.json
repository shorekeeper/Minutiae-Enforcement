        "href": "../keyword/const.html"
      }
    ]
  },
  "L003": {
    "title": "Invalid text escape",
    "canonicalMessage": "invalid escape '\\<character>'",
    "cause": [
      "A backslash inside a text literal is followed by a character outside the supported escape set.",
      "The supported escapes are double quote, backslash, n, t, and r. The lexer reports the unsupported escape and continues scanning the surrounding text literal."
    ],
    "example": "const Text path = \"bad\\qescape\";",
    "exampleLanguage": "alam",
    "remedy": [
      "Use one of the supported escape sequences: \\\" for a quote, \\\\ for a backslash, \\n for newline, \\t for tab, or \\r for carriage return.",
      "Remove the backslash when the following character is intended literally."
    ],
    "related": [
      {
        "label": "Text",
        "href": "../type/Text.html",
        "group": "Entity"
      },
      {
        "label": "Lexical structure",
        "href": "../guide/lexical.html",
        "group": "Model"
      }
    ]
  },
  "L004": {
    "title": "Malformed duration literal",
    "canonicalMessage": "malformed duration literal '<literal>'",
    "cause": [
      "A decimal digit run followed by a duration unit begins one duration token, but the complete token does not preserve strict digit-unit alternation.",
      "A malformed suffix remains part of the same erroneous duration token. It is not split into a shorter valid duration followed by another token."
    ],
    "example": "const Duration span = 3hx;",
    "exampleLanguage": "alam",
    "remedy": [
      "Write the duration as one or more complete integer-unit segments.",
      "Supported units are s, m, h, d, and w. For example, use 3h, 1h30m, or 2w3d."
    ],
    "related": [
      {
        "label": "Duration",
        "href": "../type/Duration.html",
        "group": "Entity"
      },
      {
        "label": "Lexical structure",
        "href": "../guide/lexical.html",
