  "P009": {
    "title": "Empty template constraint block",
    "canonicalMessage": "constraint block must contain at least one constraint",
    "cause": [
      "A where block closes without containing any constraint expression.",
      "The where clause exists only to impose one or more pure Bool constraints. An empty block has no distinct semantic meaning."
    ],
    "example": "template<Measure M>\nwhere {\n}\nverdict policy = (event) -> Sanction {\n    .target = event.subject,\n    .cite = { P.1.1 },\n    .measure = M,\n    .duration = Duration::Permanent,\n    .escalation = Escalation::None,\n    .annotations = {},\n    .attribution = Attribution::System,\n    .dry_run = DryRun::InheritSafety,\n};",
    "exampleLanguage": "alam",
    "remedy": [
      "Add at least one pure Bool constraint to the where block.",
      "Remove the complete where block when the template has no constraints."
    ],
    "related": [
