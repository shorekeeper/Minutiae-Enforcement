{
  "L001": {
    "title": "Unexpected character",
    "canonicalMessage": "unexpected character '<character>'",
    "cause": [
      "The lexer encountered a character that does not begin any ALAM token.",
      "The offending character is emitted as an ERROR token. Lexing then resumes at the following character so later source positions remain diagnosable."
    ],
    "example": "const Int value = 1 @ 2;",
    "exampleLanguage": "alam",
    "remedy": [
      "Remove the unsupported character or replace it with the intended ALAM operator or punctuation.",
      "If the character belongs to text data, place it inside a double-quoted text literal."
    ],
    "related": [
      {
        "label": "Lexical structure",
        "href": "../guide/lexical.html",
        "group": "Model"
      },
      {
        "label": "const",
        "href": "../keyword/const.html",
        "group": "Example context"
      }
    ]
  },
  "L002": {
    "title": "Unterminated text literal",
    "canonicalMessage": "unterminated text literal",
    "cause": [
      "A double-quoted text literal reached the end of the source before a closing double quote was found.",
      "A newline does not terminate a text literal. Scanning continues until a closing quote or the end of the complete source."
    ],
    "example": "const Text reason = \"missing closing quote;",
    "exampleLanguage": "alam",
    "remedy": [
      "Add the closing double quote.",
      "To include a literal double quote inside the value, escape it as \\\"."
    ],
    "related": [
      {
        "label": "Lexical structure",
        "href": "../guide/lexical.html",
        "group": "Model"
      },
