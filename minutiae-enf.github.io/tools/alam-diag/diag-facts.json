    "example": "template<Measure>\nverdict policy = (event) -> Sanction {\n    .target = event.subject,\n    .cite = { P.1.1 },\n    .measure = Measure::CUSTODY,\n    .duration = Duration::Permanent,\n    .escalation = Escalation::None,\n    .annotations = {},\n    .attribution = Attribution::System,\n    .dry_run = DryRun::InheritSafety,\n};",
